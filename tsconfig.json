{
  "compilerOptions": {
    "noImplicitAny": true,
    "esModuleInterop": true,
    "lib": ["DOM", "ESNext"],
    "target": "es2016",
    "moduleResolution": "bundler",
    "allowJs": true,
    "module": "esnext",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["google.maps", "jest"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*", "examples/**/*"],
  "exclude": ["node_modules", "dist"]
}
